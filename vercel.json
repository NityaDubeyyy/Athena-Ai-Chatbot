{
  "version": 2,
  "buildCommand": "npm install && npm run build",
  "devCommand": "cd server && npm install && npm run dev",
  "env": {
    "NODE_ENV": "production"
  },
  "builds": [
    {
      "src": "server/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/server/server.js"
    }
  ]
}
